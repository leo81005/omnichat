{
  "name": "omnichat",
  "version": "1.0.0",
  "description": "Chat with multiple AI models simultaneously - send text, files and images to ChatGPT, Claude, Gemini, Perplexity and Grok in one unified interface",
  "author": {
    "name": "leo81005"
  },
  "main": "src/main/index.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.7.3"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.omnichat.app",
    "productName": "OmniChat",
    "publish": [
      {
        "provider": "github",
        "owner": "leo81005",
        "repo": "omnichat"
      }
    ],
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "config/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "assets/icons/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "OmniChat needs access to your microphone for voice input in ChatGPT and other chat services."
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "assets/icons/no_text.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
